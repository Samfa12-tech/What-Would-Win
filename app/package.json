{
  "name": "what-would-win-demo",
  "private": true,
  "version": "0.3.1",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "prebuild": "npm run audit:release",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "test": "npm run audit:release && vitest run",
    "audit:provenance": "node ../scripts/generate_provenance_audit.mjs",
    "audit:legal": "node ../scripts/generate_public_legal.mjs && node ../scripts/verify_runtime_notices.mjs",
    "audit:semantics": "node ../scripts/verify_creature_semantics.mjs",
    "audit:release": "npm run audit:semantics && npm run audit:provenance && npm run audit:legal",
    "test:simulation-budget": "vitest run src/test/performance.test.ts",
    "test:e2e": "npm run build && playwright test",
    "test:e2e:headed": "npm run build && playwright test --headed",
    "test:all": "npm run test && npm run test:e2e",
    "typecheck": "tsc -b --pretty false"
  },
  "dependencies": {
    "ajv": "^8.20.0",
    "ajv-formats": "^3.0.1",
    "react": "19.2.7",
    "react-dom": "19.2.7"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@playwright/test": "1.61.1",
    "@vitejs/plugin-react": "6.0.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "typescript": "7.0.2",
    "vite": "8.1.5",
    "vitest": "4.1.10"
  }
}
